{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "types": ["node", "bun"],
    "outDir": "dist-ts",
    "paths": {
      "@cr/core": ["./packages/core/src/index.ts"],
      "@cr/workflows": ["./packages/workflows/src/index.ts"],
      "@cr/tui": ["./packages/cli/src/tui/index.ts"],
      "@cr/web": ["./packages/web/src/index.ts"],
      "@cr/server": ["./packages/server/src/index.ts"],
      "@cr/vcs/github": ["./packages/vcs/src/github/index.ts"],
      "@cr/vcs/gitlab": ["./packages/vcs/src/gitlab/index.ts"],
      "@cr/vcs/reviewboard": ["./packages/vcs/src/reviewboard/index.ts"],
      "@cr/desktop": ["./packages/desktop/src/bun/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*"]
}
